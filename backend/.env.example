# Exemplo de variáveis de ambiente para o backend

# URI de conexão MongoDB
# Em Heroku, use a variável MONGODB_URI ou DATABASE_URL fornecida pelo addon.
MONGODB_URI=mongodb://username:password@host:port/financeiro

# Segredo JWT usado para assinar tokens
JWT_SECRET=seu-super-segredo-jwt

# Porta local (não é necessária no Heroku)
PORT=8081
